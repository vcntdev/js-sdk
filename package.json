{
  "name": "@lunogram/js-sdk",
  "version": "0.0.0",
  "description": "Lunogram Javascript SDK for collecting events",
  "scripts": {
    "build": "rimraf lib/ && pnpm run build:esm && pnpm run build:cjs",
    "build:esm": "tsc --project ./tsconfig.module.json",
    "build:cjs": "tsc --project ./tsconfig.json",
    "lint": "eslint . --ext .ts",
    "release:github": "pnpm publish --no-git-checks --registry=https://npm.pkg.github.com",
    "release:npm": "pnpm publish --no-git-checks --access public --registry=https://registry.npmjs.org"
  },
  "types": "./lib/cjs/index.d.ts",
  "main": "./lib/cjs/index.js",
  "module": "./lib/esm/index.js",
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "keywords": [
    "lunogram",
    "js"
  ],
  "contributors": [
    {
      "name": "Jeroen Rinzema"
    },
    {
      "name": "Chris Anderson"
    }
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "eslint": "^9.37.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.46.0"
  },
  "files": [
    "lib"
  ]
}